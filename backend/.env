# ============================================
# SaPyme Backend - Entorno de Desarrollo Local
# ============================================

# --- Servidor ---
NODE_ENV=development
PORT=3000

# --- Base de Datos PostgreSQL ---
DB_HOST=database
DB_PORT=5432
DB_NAME=saas_pymes
DB_USER=postgres
DB_PASSWORD=admin123_secure_local_2024

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass_2024
REDIS_DB=0

# --- JWT (mínimo 256 caracteres recomendado) ---
JWT_SECRET=jwt_secret_super_seguro_para_desarrollo_local_2024_muy_largo_64_chars_minimo_este_es_ejemplo_jwt_secret_super_seguro_para_desarrollo_local_2024_muy_largo_64_chars_minimo
JWT_EXPIRES=8h

# --- Bootstrap Super Admin (solo para setup inicial) ---
BOOTSTRAP_DISABLED=false
BOOTSTRAP_SUPER_ADMIN_SECRET=bootstrap_super_admin_secret_seguro_para_desarrollo_local_2024

# --- Microservicios ---
ML_SERVICE_URL=http://ml_service:8000/api
ML_SERVICE_API_KEY=ml_service_api_key_desarrollo_local_2024_seguro
FACTURACION_SERVICE_URL=http://facturacion_service:9000/api
FACTURACION_TIMEOUT_MS=15000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Seguridad ---
REQUIRE_HTTPS=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=150

# --- Stripe (opcional para desarrollo) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Email (opcional para desarrollo) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@sapyme.local

