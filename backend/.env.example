# ============================================
# SaPyme Backend - Entorno Local
# Copiar a backend/.env solo si ejecutas el backend fuera de Docker.
# Para Docker Compose usa .env en la raíz del repositorio.
# ============================================

NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=saas_pymes
DB_USER=sapyme_app
DB_PASSWORD=REEMPLAZAR_CON_PASSWORD_POSTGRES_LOCAL

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REEMPLAZAR_CON_PASSWORD_REDIS_LOCAL
REDIS_DB=0

JWT_SECRET_EMPRESA=REEMPLAZAR_CON_JWT_EMPRESA_MINIMO_64_CARACTERES
JWT_SECRET_ADMIN=REEMPLAZAR_CON_JWT_ADMIN_MINIMO_64_CARACTERES
JWT_SECRET=REEMPLAZAR_CON_JWT_LEGACY_MINIMO_64_CARACTERES
JWT_EXPIRES=8h

BOOTSTRAP_DISABLED=false
BOOTSTRAP_SUPER_ADMIN_SECRET=REEMPLAZAR_CON_SECRETO_BOOTSTRAP_LOCAL

ML_SERVICE_URL=http://localhost:8000/api
ML_SERVICE_API_KEY=REEMPLAZAR_CON_API_KEY_ML_LOCAL
FACTURACION_SERVICE_URL=http://localhost:8080/api
FACTURACION_TIMEOUT_MS=15000

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
REQUIRE_HTTPS=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=150

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@sapyme.local
