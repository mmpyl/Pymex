```gitignore
# Dependencies
node_modules/
venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
*.env.*

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
```