```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.css.map

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled Binary Files
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```
