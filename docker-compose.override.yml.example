# Docker Compose override para desarrollo local
# Copiar a docker-compose.override.yml y personalizar

services:
  postgres:
    environment:
      POSTGRES_PASSWORD: tu_password_seguro_local

  backend:
    environment:
      DB_PASSWORD: tu_password_seguro_local
      JWT_SECRET: tu_jwt_secreto_muy_largo_y_seguro_para_desarrollo_2024
      NODE_ENV: development

  ml_service:
    environment:
      DB_PASSWORD: tu_password_seguro_local

  facturacion_service:
    environment:
      DB_PASSWORD: tu_password_seguro_local
      APP_ENV: development
      SUNAT_RUC: "20123456789"
      SUNAT_USER: MODDATOS
      SUNAT_PASSWORD: moddatos
