# ============================================
# SaPyme - Variables de Entorno para Docker
# Copiar este archivo a .env y ajustar valores
# ============================================

# --- Servidor Backend ---
NODE_ENV=production
PORT=3000

# --- Base de Datos PostgreSQL ---
DB_HOST=database
DB_PORT=5432
DB_NAME=saas_pymes
DB_USER=sapyme_app
# Generar con: openssl rand -base64 32
DB_PASSWORD=REEMPLAZAR_CON_PASSWORD_POSTGRES_UNICO

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# Generar con: openssl rand -base64 32
REDIS_PASSWORD=REEMPLAZAR_CON_PASSWORD_REDIS_UNICO
REDIS_DB=0

# --- JWT (Generar valores nuevos para cada ambiente) ---
# Ejecutar: openssl rand -base64 64
JWT_SECRET_EMPRESA=REEMPLAZAR_CON_JWT_EMPRESA_MINIMO_64_CARACTERES
JWT_SECRET_ADMIN=REEMPLAZAR_CON_JWT_ADMIN_MINIMO_64_CARACTERES
JWT_SECRET=REEMPLAZAR_CON_JWT_LEGACY_MINIMO_64_CARACTERES
JWT_EXPIRES=8h

# --- Bootstrap Super Admin (Desactivar después del setup inicial) ---
BOOTSTRAP_DISABLED=false
BOOTSTRAP_SUPER_ADMIN_SECRET=REEMPLAZAR_CON_SECRETO_BOOTSTRAP_UNICO

# --- Microservicios ---
ML_SERVICE_URL=http://ml_service:8000/api
ML_SERVICE_API_KEY=REEMPLAZAR_CON_API_KEY_ML_UNICA
FACTURACION_SERVICE_URL=http://facturacion_service:80/api
FACTURACION_TIMEOUT_MS=15000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://tu-dominio.com

# --- Seguridad ---
REQUIRE_HTTPS=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=150

# --- Stripe (opcional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Email (opcional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tudominio.com

# --- ML Service ---
ML_ALLOWED_ORIGINS=http://backend:3000,http://localhost:3001
