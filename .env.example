# ============================================
# SaPyme - Variables de Entorno para Docker
# Copiar este archivo a .env y ajustar valores
# ============================================

# --- Servidor Backend ---
NODE_ENV=production
PORT=3000

# --- Base de Datos PostgreSQL ---
DB_HOST=database
DB_PORT=5432
DB_NAME=saas_pymes
DB_USER=postgres
DB_PASSWORD=cambiar_por_password_seguro

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=cambiar_por_password_seguro
REDIS_DB=0

# --- JWT (Generar uno nuevo para producción) ---
# Ejecutar: openssl rand -base64 32
JWT_SECRET=cambiar_por_jwt_secret_muy_largo_y_seguro_minimo_64_caracteres
JWT_EXPIRES=8h

# --- Bootstrap Super Admin (Desactivar después del setup inicial) ---
BOOTSTRAP_DISABLED=false
BOOTSTRAP_SUPER_ADMIN_SECRET=cambiar_por_secreto_seguro

# --- Microservicios ---
ML_SERVICE_URL=http://ml_service:8000/api
ML_SERVICE_API_KEY=cambiar_por_api_key_seguro
FACTURACION_SERVICE_URL=http://facturacion_service:80/api
FACTURACION_TIMEOUT_MS=15000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://tu-dominio.com

# --- Seguridad ---
REQUIRE_HTTPS=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=150

# --- Stripe (opcional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Email (opcional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tudominio.com

# --- ML Service ---
ML_ALLOWED_ORIGINS=http://backend:3000,http://localhost:3001
